# API Key para proteger os endpoints do bot
API_KEY=

# Provedor de API para buscar shortcodes: "rapidapi" ou "hikerapi"
SHORTCODE_API_PROVIDER=rapidapi

# RapidAPI Key (se SHORTCODE_API_PROVIDER=rapidapi)
RAPIDAPI_KEY=

# HikerAPI Key (se SHORTCODE_API_PROVIDER=hikerapi)
HIKERAPI_KEY=

# Proxy residencial (Evomi ou similar)
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# Auth do Instagram (base64 do storageState) - para Railway/producao
# Localmente, use o arquivo src/instagram-auth.json
INSTAGRAM_AUTH_DATA=
